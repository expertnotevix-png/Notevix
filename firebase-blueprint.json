{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "class": { "type": "string", "enum": ["8", "9", "10"] },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "savedNotes": { "type": "array", "items": { "type": "string" } },
        "totalFocusMinutes": { "type": "number" },
        "totalPoints": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralCount": { "type": "number" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "Chapter-wise notes and important questions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "keyPoints": { "type": "array", "items": { "type": "string" } },
        "formulas": { "type": "array", "items": { "type": "string" } },
        "diagrams": { "type": "array", "items": { "type": "string" } },
        "importantQuestions": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          } 
        },
        "pdfUrl": { "type": "string" },
        "isPremium": { "type": "boolean" }
      },
      "required": ["class", "subject", "title"]
    },
    "Doubt": {
      "title": "Doubt",
      "description": "AI Chat history for student doubts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query", "response"]
    },
    "SubjectResource": {
      "title": "SubjectResource",
      "description": "Subject-level PDF resources",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "onePageNotesUrl": { "type": "string" },
        "fullNotesUrl": { "type": "string" },
        "importantQuestionsUrl": { "type": "string" },
        "examOrientedQuestionsUrl": { "type": "string" }
      },
      "required": ["class", "subject"]
    },
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "Public profile data for leaderboard",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalFocusMinutes": { "type": "number" },
        "totalPoints": { "type": "number" },
        "class": { "type": "string" }
      },
      "required": ["uid", "displayName", "totalPoints"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact messages from users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "reply": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "message"]
    },
    "ScheduleTask": {
      "title": "ScheduleTask",
      "description": "Daily schedule tasks",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "task": { "type": "string" },
        "time": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string" }
      },
      "required": ["userId", "task", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["streak", "rank", "system", "reply", "best_answer", "warning"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message"]
    },
    "Post": {
      "title": "Post",
      "description": "Community forum post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string", "enum": ["Science", "Maths", "SST", "English", "Hindi", "Other"] },
        "class": { "type": "string", "enum": ["Class 8", "Class 9", "Class 10"] },
        "upvotes": { "type": "array", "items": { "type": "string" } },
        "downvotes": { "type": "array", "items": { "type": "string" } },
        "replyCount": { "type": "number" },
        "isSolved": { "type": "boolean" },
        "bestReplyId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "description", "subject", "class", "status", "createdAt"]
    },
    "Reply": {
      "title": "Reply",
      "description": "Community forum reply",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "upvotes": { "type": "array", "items": { "type": "string" } },
        "downvotes": { "type": "array", "items": { "type": "string" } },
        "isBest": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "text", "status", "createdAt"]
    },
    "CommunityStats": {
      "title": "CommunityStats",
      "description": "Global community statistics",
      "type": "object",
      "properties": {
        "totalQuestions": { "type": "number" },
        "totalAnswers": { "type": "number" },
        "totalStudents": { "type": "number" },
        "solvedToday": { "type": "number" },
        "lastResetDate": { "type": "string" }
      }
    },
    "UserModeration": {
      "title": "UserModeration",
      "description": "User moderation status and strikes",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "strikes": { "type": "number" },
        "banUntil": { "type": "string", "format": "date-time" },
        "isPermanentlyBanned": { "type": "boolean" }
      },
      "required": ["userId", "strikes"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Public leaderboard data"
    },
    "/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Chapter notes and questions"
    },
    "/doubts/{doubtId}": {
      "schema": "Doubt",
      "description": "AI doubt solver history"
    },
    "/subject_resources/{resourceId}": {
      "schema": "SubjectResource",
      "description": "Subject-level resources"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Contact messages"
    },
    "/schedule/{taskId}": {
      "schema": "ScheduleTask",
      "description": "Daily schedule tasks"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app notifications"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community forum posts"
    },
    "/posts/{postId}/replies/{replyId}": {
      "schema": "Reply",
      "description": "Replies to a post"
    },
    "/community_stats/global": {
      "schema": "CommunityStats",
      "description": "Global community stats"
    },
    "/user_moderation/{userId}": {
      "schema": "UserModeration",
      "description": "User moderation data"
    }
  }
}
