{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "class": { "type": "string", "enum": ["8", "9", "10"] },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "savedNotes": { "type": "array", "items": { "type": "string" } },
        "totalFocusMinutes": { "type": "number" },
        "totalPoints": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "referralCount": { "type": "number" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "Chapter-wise notes and important questions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "keyPoints": { "type": "array", "items": { "type": "string" } },
        "formulas": { "type": "array", "items": { "type": "string" } },
        "diagrams": { "type": "array", "items": { "type": "string" } },
        "importantQuestions": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            }
          } 
        },
        "pdfUrl": { "type": "string" },
        "isPremium": { "type": "boolean" }
      },
      "required": ["class", "subject", "title"]
    },
    "Doubt": {
      "title": "Doubt",
      "description": "AI Chat history for student doubts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query", "response"]
    },
    "SubjectResource": {
      "title": "SubjectResource",
      "description": "Subject-level PDF resources",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "onePageNotesUrl": { "type": "string" },
        "fullNotesUrl": { "type": "string" },
        "importantQuestionsUrl": { "type": "string" },
        "examOrientedQuestionsUrl": { "type": "string" }
      },
      "required": ["class", "subject"]
    },
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "Public profile data for leaderboard",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalFocusMinutes": { "type": "number" },
        "totalPoints": { "type": "number" },
        "class": { "type": "string" }
      },
      "required": ["uid", "displayName", "totalPoints"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact messages from users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "replied"] },
        "reply": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "message"]
    },
    "ScheduleTask": {
      "title": "ScheduleTask",
      "description": "Daily schedule tasks",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "task": { "type": "string" },
        "time": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string" }
      },
      "required": ["userId", "task", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["streak", "rank", "system"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Public leaderboard data"
    },
    "/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Chapter notes and questions"
    },
    "/doubts/{doubtId}": {
      "schema": "Doubt",
      "description": "AI doubt solver history"
    },
    "/subject_resources/{resourceId}": {
      "schema": "SubjectResource",
      "description": "Subject-level resources"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Contact messages"
    },
    "/schedule/{taskId}": {
      "schema": "ScheduleTask",
      "description": "Daily schedule tasks"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app notifications"
    }
  }
}
