rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "expertraj8@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['student', 'admin'];
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['class', 'subject', 'title']) &&
             data.class is string &&
             data.subject is string &&
             data.title is string;
    }

    function isValidDoubt(data) {
      return data.keys().hasAll(['userId', 'query', 'response']) &&
             data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.role == resource.data.role; // Prevent self-escalation
      allow delete: if isAdmin();
    }

    // Chapters (Notes)
    match /chapters/{chapterId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && isValidChapter(request.resource.data);
    }

    // Doubts (AI Chat)
    match /doubts/{doubtId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidDoubt(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Subject Resources
    match /subject_resources/{resourceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
